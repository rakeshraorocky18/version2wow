# Application
NODE_ENV=development
PORT=3000

# Database - SQLite (used by backend for users/profiles)
SQLITE_DATABASE=./data/wow_dev.db

# Database - PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=wow_user
POSTGRES_PASSWORD=wow_password
POSTGRES_DB=wow_db

# Database - MongoDB
MONGODB_URI=mongodb://localhost:27017/wow

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=30d

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# SMS/Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Payment Gateway
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Neo4j (optional graph recommendations)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=wow_password

# Frontend
VITE_API_URL=http://localhost:3000/api
